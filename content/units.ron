// content/units.ron
// ═══════════════════════════════════════════════════════════════
// 兵种配置格式说明
// ═══════════════════════════════════════════════════════════════
//
// 文件格式：RON (Rusty Object Notation)
//   顶层为 Map { key: Struct(...), ... }
//   Struct 使用 (field: value) 括号语法
//   尾部逗号可选，但建议保留以便 diff 友好
//
// 字段说明（所有数值均为游戏内部单位）：
//   health:             生命值 (1 ~ 10000)
//   attack:             基础攻击力 (1 ~ 10000)
//   speed:              移动速度 (内部单位/Tick, 1 ~ 500)
//   attack_range:       攻击距离 (内部单位, 1 ~ 2000)
//   aggression_range:   主动索敌距离 (内部单位)
//   attack_interval_ticks: 攻击冷却间隔 (Tick 数, 20Hz下10=0.5秒)
//   spawn_speed_mult:   城池产兵速度倍率 (0.1 ~ 10.0)
//
// 新增兵种：
//   1. 复制一个现有条目，修改 key 名
//   2. 在 simulation/src/types.rs 的 SoldierType 枚举中添加对应变体
//   3. 在 simulation/src/soldier/config.rs 的 from_ron 中添加映射
//   4. 重启游戏生效
// ═══════════════════════════════════════════════════════════════

{
    "militia": (
        health: 100,
        attack: 16,
        speed: 80,
        attack_range: 30,
        aggression_range: 150,
        attack_interval_ticks: 10,
        spawn_speed_mult: 1.0,
    ),
    "infantry": (
        health: 100,
        attack: 20,
        speed: 80,
        attack_range: 30,
        aggression_range: 150,
        attack_interval_ticks: 10,
        spawn_speed_mult: 0.5,
    ),
    "archer": (
        health: 100,
        attack: 20,
        speed: 80,
        attack_range: 600,
        aggression_range: 600,
        attack_interval_ticks: 10,
        spawn_speed_mult: 0.5,
    ),
    "cavalry": (
        health: 140,
        attack: 20,
        speed: 200,
        attack_range: 30,
        aggression_range: 200,
        attack_interval_ticks: 10,
        spawn_speed_mult: 0.3,
    ),
}
