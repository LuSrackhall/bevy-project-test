// content/combat.ron
// ═══════════════════════════════════════════════════════════════
// 战斗公式配置 — RON struct 格式
// 修改后重启游戏生效，无需重新编译。
// ═══════════════════════════════════════════════════════════════
(
    city_damage_per_soldier_ratio: 0.5,
    archer_melee_range: 50,
    archer_melee_damage_mult: 0.85,
    shield: (
        speed_penalty: 30,
        damage_reduction: 0.80,
        intercept_chance: 0.70,
    ),
    cavalry: (
        dodge_max_chance: 0.50,
        dodge_decay_rate: 0.35,
    ),
    archer_multi_shot: (
        base_chance: 0.05,
        per_level_bonus: 0.005,
        min_chance: 0.05,
        max_chance: 0.30,
    ),
    slow_debuff: (
        base_amount: 0.85,
        stack_mult: 0.90,
        max_reduction: 0.35,
        duration_ticks: 20,
        max_stacks: 9,
    ),
    level_up: (
        exp_per_kill: 1,
        exp_to_level: 100,
        hp_gain: 30,
        attack_gain: 6,
        lifesteal_unlock_level: 4,
        lifesteal_rate: 0.10,
    ),
    fearless: (
        duration_ticks: 40,
        attack_bonus: 10,
        lifesteal_bonus: 0.15,
    ),
)
